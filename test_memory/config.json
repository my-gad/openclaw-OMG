{
  "version": "1.5.0",
  "memory_dir": "test_memory",
  "storage": {
    "backend": "sqlite",
    "sqlite_path": "./memory/layer2/memory.db",
    "wal_mode": true
  },
  "retrieval": {
    "top_k": 10,
    "score_threshold": 0.5,
    "use_hybrid": true
  },
  "decay": {
    "fact_decay_rate": 0.95,
    "belief_decay_rate": 0.9,
    "summary_decay_rate": 0.85,
    "archive_threshold": 0.05
  },
  "consolidation": {
    "auto_consolidate": true,
    "consolidation_interval_hours": 24
  },
  "llm": {
    "enabled": true,
    "model": "default",
    "timeout_seconds": 30
  }
}